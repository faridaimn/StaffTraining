@page "/reports"
@using Testing.Components.Data
@using Testing.Components.Model
@rendermode InteractiveServer
@inject EmployeeService DbService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

@* ===== TAB NAVIGATION ===== *@
<div class="tab-navigation">
    <button class="tab-btn @(activeTab == "user" ? "active" : "")" @onclick='() => SetActiveTab("user")'>
        <i class="bi bi-people-fill"></i>
        User Statistics
    </button>
    <button class="tab-btn @(activeTab == "vehicle" ? "active" : "")" @onclick='() => SetActiveTab("vehicle")'>
        <i class="bi bi-truck"></i>
        Vehicle Statistics
    </button>
</div>

@* ===== USER TAB CONTENT ===== *@
@if (activeTab == "user")
{
    <div class="tab-content">
        <div class="stat-section">

            <div class="row g-3">

                @* ===== GENDER CARD ===== *@
                <div class="col-md-6">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(167,139,250,0.25);">👤</div>
                            <div>
                                <h5>Gender Statistics</h5>
                                <span class="sub">Person breakdown by gender</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="gender-chart" style="height: 300px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; cursor:pointer;"
                                 @onclick='() => Navigation.NavigateTo("/personlist/hasGender")'>
                                <span style="font-weight:600; color:#334155;">Sub-total Gender</span>
                                <span style="font-weight:700; color:#7c3aed; text-decoration:underline;">@genderTotal</span>
                            </div>
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; background:#1e293b; margin:0 -20px -20px -20px; padding:15px 20px; border-radius:0 0 12px 12px; cursor:pointer;"
                                 @onclick='() => Navigation.NavigateTo("/personlist/all")'>
                                <span style="font-weight:700; color:white;">Grand Total</span>
                                <span style="font-weight:700; color:white; font-size:18px; text-decoration:underline;">@totalEmployees</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== NATIONALITY CARD ===== *@
                <div class="col-md-6">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(52,211,153,0.25);">🌍</div>
                            <div>
                                <h5>Nationality Statistics</h5>
                                <span class="sub">Person breakdown by nationality</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="nationality-chart" style="height: 300px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; cursor:pointer;"
                                 @onclick='() => Navigation.NavigateTo("/personlist/hasNationality")'>
                                <span style="font-weight:600; color:#334155;">Sub-total Nationality</span>
                                <span style="font-weight:700; color:#059669; text-decoration:underline;">@nationalityTotal</span>
                            </div>
                            <div style="display:flex; justify-content:space-between; align-items:center; background:#1e293b; margin:0 -20px -20px -20px; padding:15px 20px; border-radius:0 0 12px 12px; cursor:pointer;"
                                 @onclick='() => Navigation.NavigateTo("/personlist/all")'>
                                <span style="font-weight:700; color:white;">Grand Total</span>
                                <span style="font-weight:700; color:white; font-size:18px; text-decoration:underline;">@totalEmployees</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== MARITAL STATUS CARD ===== *@
                <div class="col-md-6">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(251,191,36,0.25);">💍</div>
                            <div>
                                <h5>Marital Status Statistics</h5>
                                <span class="sub">Person breakdown by marital status</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="marital-chart" style="height: 300px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;">
                                <span style="font-weight: 600; color: #334155;">Sub-total Marital Status</span>
                                <span style="font-weight: 700; color: #d97706;">@maritalTotal</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; background: #1e293b; margin: 0 -20px -20px -20px; padding: 15px 20px; border-radius: 0 0 12px 12px;">
                                <span style="font-weight: 700; color: white;">Grand Total</span>
                                <span style="font-weight: 700; color: white; font-size: 18px;">@totalEmployees</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== BIRTH YEAR CARD ===== *@
                <div class="col-md-6">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(59,130,246,0.25);">🎂</div>
                            <div>
                                <h5>Birth Year Statistics</h5>
                                <span class="sub">Person breakdown by birth year</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="birthyear-chart" style="height: 300px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;">
                                <span style="font-weight: 600; color: #334155;">Sub-total Birth Year</span>
                                <span style="font-weight: 700; color: #2563eb;">@birthYearTotal</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; background: #1e293b; margin: 0 -20px -20px -20px; padding: 15px 20px; border-radius: 0 0 12px 12px;">
                                <span style="font-weight: 700; color: white;">Grand Total</span>
                                <span style="font-weight: 700; color: white; font-size: 18px;">@totalEmployees</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @* ===== GRAND TOTAL CARD ===== *@
            <div class="row mt-4">
                <div class="col-12">
                    <div class="grand-total-card">
                        <div class="grand-total-content">
                            <div class="grand-total-icon">
                                <i class="bi bi-trophy-fill"></i>
                            </div>
                            <div class="grand-total-text">
                                <span class="grand-total-label">GRAND TOTAL</span>
                                <span class="grand-total-value">@totalEmployees</span>
                                <span class="grand-total-sub">Total Person Records</span>
                            </div>
                            <div class="grand-total-stats">
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Gender</span>
                                    <span class="stat-badge-value">@genderStats.Count types</span>
                                </div>
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Nationality</span>
                                    <span class="stat-badge-value">@nationalityStats.Count countries</span>
                                </div>
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Marital</span>
                                    <span class="stat-badge-value">@maritalStats.Count marital</span>
                                </div>
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Birth Years</span>
                                    <span class="stat-badge-value">@birthYearStats.Count years</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
}

@* ===== VEHICLE TAB CONTENT ===== *@
@if (activeTab == "vehicle")
{
    <div class="tab-content">
        <div class="stat-section">

            <div class="row g-3">

                @* ===== COLOR CARD ===== *@
                <div class="col-md-4">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(168,85,247,0.25);">🎨</div>
                            <div>
                                <h5>Color Statistics</h5>
                                <span class="sub">Vehicle breakdown by color</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="color-chart" style="height: 280px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;">
                                <span style="font-weight: 600; color: #334155;">Total Colors</span>
                                <span style="font-weight: 700; color: #a855f7;">@colorStats.Count types</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; background: #1e293b; margin: 0 -20px -20px -20px; padding: 15px 20px; border-radius: 0 0 12px 12px;">
                                <span style="font-weight: 700; color: white;">Total Vehicles</span>
                                <span style="font-weight: 700; color: white; font-size: 18px;">@totalVehicles</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== BRAND CARD ===== *@
                <div class="col-md-4">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(34,197,94,0.25);">🏭</div>
                            <div>
                                <h5>Brand Statistics</h5>
                                <span class="sub">Vehicle breakdown by brand</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="brand-chart" style="height: 280px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;">
                                <span style="font-weight: 600; color: #334155;">Total Brands</span>
                                <span style="font-weight: 700; color: #22c55e;">@brandStats.Count types</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; background: #1e293b; margin: 0 -20px -20px -20px; padding: 15px 20px; border-radius: 0 0 12px 12px;">
                                <span style="font-weight: 700; color: white;">Total Vehicles</span>
                                <span style="font-weight: 700; color: white; font-size: 18px;">@totalVehicles</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ===== MODEL CARD ===== *@
                <div class="col-md-4">
                    <div class="stat-card h-100">
                        <div class="stat-card-header">
                            <div class="badge-icon" style="background:rgba(249,115,22,0.25);">🚙</div>
                            <div>
                                <h5>Model Statistics</h5>
                                <span class="sub">Vehicle breakdown by model</span>
                            </div>
                        </div>

                        <div style="padding: 20px;">
                            <div id="model-chart" style="height: 280px; width: 100%;"></div>
                        </div>

                        <div style="padding: 0 20px 20px 20px; border-top: 1px solid #e2e8f0; margin-top: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0;">
                                <span style="font-weight: 600; color: #334155;">Total Models</span>
                                <span style="font-weight: 700; color: #f97316;">@modelStats.Count types</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; background: #1e293b; margin: 0 -20px -20px -20px; padding: 15px 20px; border-radius: 0 0 12px 12px;">
                                <span style="font-weight: 700; color: white;">Total Vehicles</span>
                                <span style="font-weight: 700; color: white; font-size: 18px;">@totalVehicles</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            @* ===== VEHICLE GRAND TOTAL CARD ===== *@
            <div class="row mt-4">
                <div class="col-12">
                    <div class="grand-total-card" style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);">
                        <div class="grand-total-content">
                            <div class="grand-total-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
                                <i class="bi bi-truck"></i>
                            </div>
                            <div class="grand-total-text">
                                <span class="grand-total-label">VEHICLE GRAND TOTAL</span>
                                <span class="grand-total-value">@totalVehicles</span>
                                <span class="grand-total-sub">Total Vehicle Records</span>
                            </div>
                            <div class="grand-total-stats">
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Colors</span>
                                    <span class="stat-badge-value">@colorStats.Count</span>
                                </div>
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Brands</span>
                                    <span class="stat-badge-value">@brandStats.Count</span>
                                </div>
                                <div class="stat-badge">
                                    <span class="stat-badge-label">Models</span>
                                    <span class="stat-badge-value">@modelStats.Count</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
}


@code {
    private string activeTab = "user";
    private List<EmployeeProfile>? employees;
    private List<Vehicle>? allVehicles;

    #region Variable For Gender/Nationality/Marital/Birth

    private Dictionary<string, int> genderStats = new();
    private Dictionary<string, int> nationalityStats = new();
    private Dictionary<string, int> maritalStats = new();
    private Dictionary<string, int> birthYearStats = new();
    private Dictionary<int, string> nationalityMapping = new();
    private int genderTotal = 0;
    private int nationalityTotal = 0;
    private int maritalTotal = 0;
    private int birthYearTotal = 0;
    private int totalEmployees = 0;

    #endregion

    #region Variable for Vehicle Statistics
    private Dictionary<string, int> colorStats = new();
    private Dictionary<string, int> brandStats = new();
    private Dictionary<string, int> modelStats = new();
    private int totalVehicles = 0;
    #endregion

    protected override async Task OnInitializedAsync()
    {
        employees = await DbService.GetEmployeesAsync();
        allVehicles = employees.SelectMany(e => e.Vehicles).ToList();

        await LoadNationalities();

        CalculateGenderStats();
        CalculateNationalityStats();
        CalculateMaritalStats();
        CalculateBirthYearStats();
        CalculateVehicleStats();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (employees != null && employees.Count > 0)
        {
            if (activeTab == "user")
            {
                await RenderGenderChart();
                await RenderNationalityChart();
                await RenderMaritalChart();
                await RenderBirthYearChart();
            }
            else if (activeTab == "vehicle" && totalVehicles > 0)
            {
                await RenderColorChart();
                await RenderBrandChart();
                await RenderModelChart();
            }
        }
    }


    private async Task LoadNationalities()
    {
        var nationalities = await DbService.GetNationalitiesAsync();
        nationalityMapping = nationalities.ToDictionary(n => n.Id, n => n.Name);
    }

    #region calculate stats users profile

    private void CalculateGenderStats()
    {
        genderStats = employees
                .Where(e => !string.IsNullOrEmpty(e.Gender))
                .GroupBy(e => e.Gender)
                .ToDictionary(g => g.Key, g => g.Count());

        genderTotal = genderStats.Values.Sum();
        totalEmployees = employees.Count();
    }

    private void CalculateNationalityStats()
    {
        nationalityStats = employees
                 .Where(e => e.nationality_id.HasValue && nationalityMapping.ContainsKey(e.nationality_id.Value))
                 .GroupBy(e => nationalityMapping[e.nationality_id.Value])
                 .ToDictionary(g => g.Key, g => g.Count());

        nationalityTotal = nationalityStats.Values.Sum();
    }

    private void CalculateMaritalStats()
    {
        maritalStats = employees
                .Where(e => !string.IsNullOrEmpty(e.MaritalStatus))
                .GroupBy(e => e.MaritalStatus ?? "Unknown")
                .ToDictionary(e => e.Key, e => e.Count());

        maritalTotal = maritalStats.Values.Sum();
    }

    private void CalculateBirthYearStats()
    {
        birthYearStats = employees
                .Where(e => e.BirthDate.HasValue)
                .GroupBy(e => e.BirthDate.Value.Year.ToString())
                .ToDictionary(e => e.Key, e => e.Count());

        birthYearTotal = birthYearStats.Values.Sum();
    }

    #endregion

    #region calculate stats vehicle
    private void CalculateVehicleStats()
    {
        if (allVehicles == null) return;

        // Color statistics
        colorStats = allVehicles
            .Where(v => !string.IsNullOrEmpty(v.Color))
            .GroupBy(v => v.Color)
            .ToDictionary(g => g.Key, g => g.Count());

        // Brand statistics
        brandStats = allVehicles
            .Where(v => !string.IsNullOrEmpty(v.brand))
            .GroupBy(v => v.brand)
            .ToDictionary(g => g.Key, g => g.Count());

        // Model statistics
        modelStats = allVehicles
            .Where(v => !string.IsNullOrEmpty(v.Model))
            .GroupBy(v => v.Model)
            .ToDictionary(g => g.Key, g => g.Count());

        // Total vehicles
        totalVehicles = allVehicles.Count;
    }
    #endregion

    #region FusionCharts Data Builders

    private async Task RenderGenderChart()
    {
        var data = genderStats.Select(kv => new
        {
            label = kv.Key,
            value = kv.Value.ToString()
        }).ToArray();

        await JSRuntime.InvokeVoidAsync("renderGenderChart", "gender-chart", data);
    }

    private async Task RenderNationalityChart()
    {
        var data = nationalityStats
            .OrderByDescending(kv => kv.Value)
            .Select(kv => new
            {
                label = kv.Key,
                value = kv.Value.ToString()
            }).ToArray();

        await JSRuntime.InvokeVoidAsync("renderNationalityChart", "nationality-chart", data);
    }

    #endregion

    private async Task RenderMaritalChart()
    {
        var chartConfig = new
        {
            type = "bar2d",
            renderAt = "marital-chart",
            width = "100%",
            height = "300",
            dataFormat = "json",
            dataSource = new
            {
                chart = new
                {
                    caption = "",
                    xAxisName = "Marital Status",
                    yAxisName = "Count",
                    theme = "fusion",
                    showborder = "0",
                    bgcolor = "00FFFFFF",
                    showvalues = "1",
                    plotToolText = "$label: $value persons",
                    paletteColors = "#fbbf24,#f59e0b,#d97706"
                },
                data = maritalStats.Select((kv, i) => new
                {
                    label = kv.Key,
                    value = kv.Value.ToString()
                }).ToArray()
            }
        };

        await JSRuntime.InvokeVoidAsync("renderFusionChart", "marital-chart", chartConfig);
    }

    private async Task RenderBirthYearChart()
    {
        var sortedStats = birthYearStats
            .OrderByDescending(kv => kv.Key)
            .ToList();

        var chartConfig = new
        {
            type = "bar2d",
            renderAt = "birthyear-chart",
            width = "100%",
            height = "300",
            dataFormat = "json",
            dataSource = new
            {
                chart = new
                {
                    caption = "",
                    xAxisName = "Birth Year",
                    yAxisName = "Count",
                    theme = "fusion",
                    showborder = "0",
                    bgcolor = "00FFFFFF",
                    showvalues = "1",
                    plotToolText = "$label: $value persons",
                    paletteColors = "#3b82f6,#60a5fa,#93c5fd,#bfdbfe"
                },
                data = sortedStats.Select(kv => new
                {
                    label = kv.Key,
                    value = kv.Value.ToString()
                }).ToArray()
            }
        };

        await JSRuntime.InvokeVoidAsync("renderFusionChart", "birthyear-chart", chartConfig);
    }

    #region Render Vehicle Charts
    private async Task RenderColorChart()
    {
        var sortedStats = colorStats
            .OrderByDescending(kv => kv.Value)
            .Take(10)
            .ToList();

        var chartConfig = new
        {
            type = "bar2d",
            renderAt = "color-chart",
            width = "100%",
            height = "280",
            dataFormat = "json",
            dataSource = new
            {
                chart = new
                {
                    caption = "",
                    xAxisName = "Color",
                    yAxisName = "Count",
                    theme = "fusion",
                    showborder = "0",
                    bgcolor = "00FFFFFF",
                    showvalues = "1",
                    plotToolText = "$label: $value vehicles",
                    paletteColors = "#a855f7,#c084fc,#d8b4fe,#e9d5ff"
                },
                data = sortedStats.Select(kv => new
                {
                    label = kv.Key,
                    value = kv.Value.ToString()
                }).ToArray()
            }
        };

        await JSRuntime.InvokeVoidAsync("renderFusionChart", "color-chart", chartConfig);
    }

    private async Task RenderBrandChart()
    {
        var sortedStats = brandStats
            .OrderByDescending(kv => kv.Value)
            .Take(10)
            .ToList();

        var chartConfig = new
        {
            type = "bar2d",
            renderAt = "brand-chart",
            width = "100%",
            height = "280",
            dataFormat = "json",
            dataSource = new
            {
                chart = new
                {
                    caption = "",
                    xAxisName = "Brand",
                    yAxisName = "Count",
                    theme = "fusion",
                    showborder = "0",
                    bgcolor = "00FFFFFF",
                    showvalues = "1",
                    plotToolText = "$label: $value vehicles",
                    paletteColors = "#22c55e,#4ade80,#86efac,#bbf7d0"
                },
                data = sortedStats.Select(kv => new
                {
                    label = kv.Key,
                    value = kv.Value.ToString()
                }).ToArray()
            }
        };

        await JSRuntime.InvokeVoidAsync("renderFusionChart", "brand-chart", chartConfig);
    }

    private async Task RenderModelChart()
    {
        var sortedStats = modelStats
            .OrderByDescending(kv => kv.Value)
            .Take(10)
            .ToList();

        var chartConfig = new
        {
            type = "bar2d",
            renderAt = "model-chart",
            width = "100%",
            height = "280",
            dataFormat = "json",
            dataSource = new
            {
                chart = new
                {
                    caption = "",
                    xAxisName = "Model",
                    yAxisName = "Count",
                    theme = "fusion",
                    showborder = "0",
                    bgcolor = "00FFFFFF",
                    showvalues = "1",
                    plotToolText = "$label: $value vehicles",
                    paletteColors = "#f97316,#fb923c,#fdba74,#fed7aa"
                },
                data = sortedStats.Select(kv => new
                {
                    label = kv.Key,
                    value = kv.Value.ToString()
                }).ToArray()
            }
        };

        await JSRuntime.InvokeVoidAsync("renderFusionChart", "model-chart", chartConfig);
    }
    #endregion
    
    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;

        if (tab == "user")
        {
            await RenderGenderChart();
            await RenderNationalityChart();
            await RenderMaritalChart();
            await RenderBirthYearChart();
        }
        else if (tab == "vehicle" && totalVehicles > 0)
        {
            await RenderColorChart();
            await RenderBrandChart();
            await RenderModelChart();
        }

        StateHasChanged();
    }
}
