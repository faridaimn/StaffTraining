@page "/personlist"
@page "/personlist/{gender}"
@page "/personlist/all"
@page "/personlist/nationality/{nationalityName}"
@page "/personlist/marital/{maritalStatus}"
@page "/personlist/birthyear/{birthYear}"
@using Testing.Components.Shared
@using Testing.Components.Data
@using Testing.Components.Model
@rendermode InteractiveServer
@inject EmployeeService DbService
@inject NavigationManager Navigation

<VehicleModal IsVisible="@showModal"
              PersonName="@popupPersonName"
              Vehicles="@popupVehicles"
              OnClose="@(() => showModal = false)" />

<PageTitle>Person List</PageTitle>

<div class="d-print-none">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>
                <i class="bi bi-people-fill me-2"></i>
                Person List
                <small class="fs-6 text-muted fw-normal ms-2">
                    @(!string.IsNullOrEmpty(MaritalStatus) ? $"— Marital: {MaritalStatus}" :
                                    !string.IsNullOrEmpty(BirthYear) ? $"— Birth Year: {BirthYear}" :
                                    !string.IsNullOrEmpty(NationalityName) ? $"— {NationalityName}" :
                                    Gender == "all" ? "— All" :
                                    Gender == "hasGender" ? "— Has Gender" :
                                    Gender == "hasNationality" ? "— Has Nationality" :
                                    Gender == "hasMarital" ? "— Has Marital Status" :
                                    Gender == "hasBirthYear" ? "— Has Birth Year" :
                                    !string.IsNullOrEmpty(Gender) ? $"— {Gender}" : "")
                </small>
            </h1>
            <button class="btn btn-outline-secondary shadow-sm" @onclick="GoBack">
                <i class="bi bi-arrow-left me-1"></i> Back
            </button>
    </div>

    <!-- STAT CARDS -->
    @{
        var totalRecords = persons?.Count ?? 0;
        var withVehicles = persons?.Count(p => (p.Vehicles?.Count ?? 0) > 0) ?? 0;
        var totalVehicles = persons?.Sum(p => p.Vehicles?.Count ?? 0) ?? 0;
    }
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body stat-card">
                    <div class="label"><i class="bi bi-person-lines-fill me-1"></i>Total records</div>
                    <div class="value">@totalRecords</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body stat-card">
                    <div class="label"><i class="bi bi-car-front-fill me-1"></i>With vehicles</div>
                    <div class="value">@withVehicles</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body stat-card">
                    <div class="label"><i class="bi bi-collection-fill me-1"></i>Total vehicles</div>
                    <div class="value">@totalVehicles</div>
                </div>
            </div>
        </div>
    </div>

    <!-- SEARCH & LIST SECTION -->
    <div class="card shadow-sm border-0">
        <div class="card-body px-0 py-2">

            <!-- Loading -->
            @if (persons == null)
            {
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted"><em>Loading records...</em></p>
                </div>
            }
            else if (filteredPersons.Count == 0)
            {
                <div class="alert alert-warning text-center shadow-sm">
                    No records found matching your criteria.
                </div>
            }
            else
            {
                <!-- TABLE -->
                <div class="table-responsive rounded shadow-sm">
                    <table class="table table-hover table-striped mb-0 align-middle table-bordered bg-white">
                        <thead class="table-dark text-center">
                            <tr>
                                <th class="sortable" @onclick='() => SortBy("IC_No")'>
                                    IC No
                                    @if (sortColumn == "IC_No")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("PersonName")'>
                                    Name
                                    @if (sortColumn == "PersonName")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("Gender")'>
                                    Gender
                                    @if (sortColumn == "Gender")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("MaritalStatus")'>
                                    Marital Status
                                    @if (sortColumn == "MaritalStatus")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("BirthYear")'>
                                    Birth Year
                                    @if (sortColumn == "BirthYear")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-numeric-down" : "bi-sort-numeric-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("Nationality")'>
                                    Nationality
                                    @if (sortColumn == "Nationality")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("VehicleCount")'>
                                    Vehicle Count
                                    @if (sortColumn == "VehicleCount")
                                    {
                                        <i class="bi @(sortAscending ? "bi-sort-numeric-down" : "bi-sort-numeric-down-alt") sort-icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size:0.7rem;"></i>
                                    }
                                </th>
                                <th style="min-width:140px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var person in pagedPersons)
                            {
                                var vehicleCount = person.Vehicles?.Count ?? 0;
                                <tr>
                                    <td class="text-center fw-bold">@person.IC_No</td>
                                    <td class="text-truncate" style="max-width:160px;" title="@person.PersonName">@person.PersonName</td>
                                    <td class="text-center">
                                        @if (person.Gender == "Male")
                                        {
                                            <span class="badge rounded-pill" style="background:#E6F1FB;color:#0C447C;font-size:11px;">Male</span>
                                        }
                                        else if (person.Gender == "Female")
                                        {
                                            <span class="badge rounded-pill" style="background:#FBEAF0;color:#72243E;font-size:11px;">Female</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(person.MaritalStatus))
                                        {
                                            @switch (person.MaritalStatus)
                                            {
                                                case "Single":
                                                    <span class="badge rounded-pill" style="background:#FEF3C7;color:#92400E;font-size:11px;">Single</span>
                                                    break;
                                                case "Married":
                                                    <span class="badge rounded-pill" style="background:#D1FAE5;color:#065F46;font-size:11px;">Married</span>
                                                    break;
                                                case "Divorced":
                                                    <span class="badge rounded-pill" style="background:#F3F4F6;color:#374151;font-size:11px;">Divorced</span>
                                                    break;
                                                case "Widowed":
                                                    <span class="badge rounded-pill" style="background:#E9D5FF;color:#6B21A8;font-size:11px;">Widowed</span>
                                                    break;
                                                default:
                                                    <span class="badge rounded-pill" style="background:#F3F4F6;color:#374151;font-size:11px;">@person.MaritalStatus</span>
                                                    break;
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">@(person.BirthDate?.Year.ToString() ?? "-")</td>
                                    <td class="text-center">@GetNationalityName(person.nationality_id)</td>
                                    <td class="text-center">
                                        <div class="d-flex align-items-center justify-content-center gap-2"
                                             style="cursor:pointer;"
                                             @onclick="() => ShowVehiclePopup(person.IC_No, person.PersonName)">
                                            <svg width="22" height="16" viewBox="0 0 22 16" fill="none">
                                                <path d="M4.5 6L6.5 2H15.5L17.5 6" stroke="#185FA5" stroke-width="1.4" stroke-linecap="round" />
                                                <rect x="1" y="6" width="20" height="7" rx="2" fill="#185FA5" fill-opacity="0.15" stroke="#185FA5" stroke-width="1.4" />
                                                <circle cx="5" cy="13" r="2" fill="#185FA5" />
                                                <circle cx="17" cy="13" r="2" fill="#185FA5" />
                                                <rect x="7" y="7.5" width="3.5" height="2.5" rx="0.5" fill="#185FA5" fill-opacity="0.5" />
                                                <rect x="11.5" y="7.5" width="3.5" height="2.5" rx="0.5" fill="#185FA5" fill-opacity="0.5" />
                                            </svg>
                                            <span style="font-weight:500;color:#185FA5;">@vehicleCount</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-info text-white shadow-sm"
                                                @onclick="() => ViewPersonDetail(person.IC_No)">
                                            View Details
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- PAGINATION FOOTER -->
                <div class="d-flex justify-content-between align-items-center mt-3 bg-white p-2 rounded shadow-sm border">
                    <div class="d-flex align-items-center gap-2 text-muted small">
                        <span>Show</span>
                        <select class="form-select form-select-sm" style="width:auto;" @onchange="ChangePageSize">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span>entries</span>
                        <span class="ms-2">
                            Showing @(totalFilteredCount == 0 ? 0 : (currentPage - 1) * pageSize + 1) to
                            @(Math.Min(currentPage * pageSize, totalFilteredCount)) of @totalFilteredCount entries
                        </span>
                    </div>
                    <nav aria-label="Person list pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => { currentPage--; StateHasChanged(); }">Previous</button>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageIndex = i;
                                <li class="page-item @(currentPage == pageIndex ? "active" : "")">
                                    <button class="page-link" @onclick="() => { currentPage = pageIndex; StateHasChanged(); }">@pageIndex</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => { currentPage++; StateHasChanged(); }">Next</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
