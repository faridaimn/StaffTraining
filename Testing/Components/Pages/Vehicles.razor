@page "/vehicles"
@using Testing.Components.Model
@using Testing.Components.Data
@rendermode InteractiveServer

<PageTitle>Vehicle Management</PageTitle>

<!-- MAIN PAGE -->
<div class="d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-car-front-fill me-2"></i>
            Vehicle Management
        </h1>
        <div class="d-flex gap-2" id="addNewBtnContainer">
            <button class="btn btn-success btn-lg shadow" @onclick="PrepareNewVehicleForm">
                <i class="bi bi-plus-circle me-1"></i> Add New Vehicle
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger shadow-sm">@ErrorMessage</div>
    }

    <!-- SEARCH SECTION -->
    <div id="searchSection" class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white">
            <i class="bi bi-search me-1"></i> Search & Filter Vehicles
        </div>
        <div class="card-body bg-light">
            <div class="row mb-2 align-items-end p-3 bg-white border rounded shadow-sm mx-0">
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-custom">Vehicle No</label>
                    <input type="text" class="form-control border-primary"
                           @bind="searchVehicleNo"
                           @bind:event="oninput"
                           placeholder="Search vehicle no..." />
                </div>
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-custom">Brand</label>
                    <input type="text" class="form-control"
                           @bind="searchBrand"
                           @bind:event="oninput"
                           placeholder="Search brand..." />
                </div>
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-custom">Model</label>
                    <input type="text" class="form-control"
                           @bind="searchModel"
                           @bind:event="oninput"
                           placeholder="Search model..." />
                </div>
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-custom">IC No (Owner)</label>
                    <input type="text" class="form-control"
                           @bind="searchIC"
                           @bind:event="oninput"
                           placeholder="Search owner IC..." />
                </div>
            </div>
        </div>
    </div>

    <!-- LISTING SECTION -->
    <div id="listingSection" class="card shadow-sm border-0">
        <div class="card-body bg-light">
            @if (vehicleList == null)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted"><em>Loading vehicle records...</em></p>
                </div>
            }
            else if (totalFilteredCount == 0)
            {
                <div class="alert alert-warning text-center shadow-sm">
                    No vehicles found matching your criteria.
                </div>
            }
            else
            {
                <div class="table-responsive rounded shadow-sm">
                    <table class="table table-hover table-striped mb-0 align-middle table-bordered bg-white">
                        <thead class="table-dark text-center">
                            <tr>
                                <th class="sortable" @onclick='() => SortBy("IC_No")'>
                                    IC No (Owner)
                                    @if (sortColumn == "IC_No")
                                    { <i class="bi @(sortAscending ? "bi-sort-numeric-down" : "bi-sort-numeric-down-alt") sort-icon"></i> }
                                    else { <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size: 0.7rem;"></i> }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("VehicleNo")'>
                                    Vehicle No
                                    @if (sortColumn == "VehicleNo")
                                    { <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i> }
                                    else { <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size: 0.7rem;"></i> }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("Brand")'>
                                    Brand
                                    @if (sortColumn == "Brand")
                                    { <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i> }
                                    else { <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size: 0.7rem;"></i> }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("Model")'>
                                    Model
                                    @if (sortColumn == "Model")
                                    { <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i> }
                                    else { <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size: 0.7rem;"></i> }
                                </th>
                                <th class="sortable" @onclick='() => SortBy("Color")'>
                                    Color
                                    @if (sortColumn == "Color")
                                    { <i class="bi @(sortAscending ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt") sort-icon"></i> }
                                    else { <i class="bi bi-arrow-down-up sort-icon text-muted" style="font-size: 0.7rem;"></i> }
                                </th>
                                <th style="min-width: 100px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in DisplayVehicles)
                            {
                                <tr>
                                    <td class="text-center">@v.IC_No</td>
                                    <td class="text-center">@v.VehicleNo</td>
                                    <td class="text-center">@v.brand</td>
                                    <td class="text-center">@v.Model</td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark">@v.Color</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => PrepareNewVehicleForIC(v.IC_No)" title="Add Vehicle for this owner">
                                                <i class="bi bi-plus-circle"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditVehicleFromList(v)" title="Edit">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteVehicle(v)" title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Standardized Pagination Footer (Matches User.razor) -->
                <div class="d-flex justify-content-between align-items-center mt-3 bg-white p-2 rounded shadow-sm border">
                    <div class="d-flex align-items-center gap-2 text-muted small">
                        <span>Show</span>
                        <select class="form-select form-select-sm" style="width: auto;" @onchange="ChangePageSize">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                        <span>entries</span>
                        <span class="ms-2">
                            Showing @(totalFilteredCount == 0 ? 0 : (currentPage - 1) * pageSize + 1) to 
                            @(Math.Min(currentPage * pageSize, totalFilteredCount)) of @totalFilteredCount entries
                        </span>
                    </div>

                    <nav aria-label="Vehicle list pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => { currentPage--; StateHasChanged(); }" title="Previous">Previous</button>
                            </li>
                            
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                var pageIndex = i;
                                <li class="page-item @(currentPage == pageIndex ? "active" : "")">
                                    <button class="page-link" @onclick="() => { currentPage = pageIndex; StateHasChanged(); }">@pageIndex</button>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => { currentPage++; StateHasChanged(); }" title="Next">Next</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>

    <!-- FORM SECTION -->
    <div id="formSection" style="display: none;" class="card shadow-sm border-0 mt-3">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center theme-header">
            <h5 class="mb-0">
                <i class="bi @(isEditing ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                @(isEditing ? "Edit Vehicle Records" : "Register New Vehicles")
            </h5>
            <button class="btn btn-sm btn-light shadow-sm fw-bold" @onclick="HideFormClientSide">
                <i class="bi bi-arrow-left"></i> Back to List
            </button>
        </div>

        <div class="card-body bg-light">
            <div class="row">
                <!-- FORM CARD -->
                <div class="col-12 mb-4">
                    <div class="card p-4 border-0 shadow-sm">
                        <h6 class="form-section-title">
                            <i class="bi bi-info-circle me-2"></i>Vehicle Information
                        </h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">IC No (Owner)</label>
                                <input type="text" class="form-control border-primary" @bind="newVehicle.IC_No" placeholder="e.g. 950228-02-5678" maxlength="14" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Vehicle No</label>
                                <input type="text"
                                       class="form-control @(!string.IsNullOrEmpty(vehicleNoDuplicateError) ? "border-danger bg-light-danger" : "")"
                                       value="@newVehicle.VehicleNo"
                                       @oninput="ValidateVehicleNo"
                                       placeholder="e.g. WA1234B"
                                       maxlength="20" />
                                @if (!string.IsNullOrEmpty(vehicleNoDuplicateError))
                                {
                                    <div class="text-danger small mt-1 fw-bold">
                                        <i class="bi bi-exclamation-circle-fill me-1"></i> @vehicleNoDuplicateError
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6 position-relative">
                                <label class="form-label-custom">Brand</label>
                                <div class="position-relative">
                                    <input class="form-control pe-4"
                                           value="@newVehicle.brand"
                                           @oninput="FilterBrands"
                                           @onfocus="ShowAllBrands"
                                           @onblur="HideBrands"
                                           placeholder="Search or select brand..." />
                                    <span class="position-absolute top-50 end-0 translate-middle-y pe-2 text-muted"
                                          style="pointer-events:none;">&#9660;</span>
                                </div>
                                @if (filteredBrands.Any())
                                {
                                    <ul class="list-group position-absolute z-3 shadow"
                                        style="width:100%; max-height:200px; overflow-y:auto; top:100%; left:0;">
                                        @foreach (var brand in filteredBrands)
                                        {
                                            <li class="list-group-item list-group-item-action"
                                                @onmousedown="() => SelectBrand(brand)">
                                                @brand
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                            <div class="col-md-6 position-relative">
                                <label class="form-label-custom">Model</label>
                                <div class="position-relative">
                                    <input class="form-control pe-4"
                                           value="@newVehicle.Model"
                                           @oninput="FilterModels"
                                           @onfocus="ShowAllModels"
                                           @onblur="HideModels"
                                           placeholder="Search or select model..."
                                           disabled="@(string.IsNullOrEmpty(newVehicle.brand))" />
                                    <span class="position-absolute top-50 end-0 translate-middle-y pe-2 text-muted"
                                          style="pointer-events:none;">&#9660;</span>
                                </div>
                                @if (filteredModels.Any())
                                {
                                    <ul class="list-group position-absolute z-3 shadow"
                                        style="width:100%; max-height:200px; overflow-y:auto; top:100%; left:0;">
                                        @foreach (var model in filteredModels)
                                        {
                                            <li class="list-group-item list-group-item-action"
                                                @onmousedown="() => SelectModel(model)">
                                                @model
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Color</label>
                                <select class="form-select" @bind="newVehicle.Color">
                                    <option value="">-- Select Color --</option>
                                    <option value="White">White</option>
                                    <option value="Black">Black</option>
                                    <option value="Silver">Silver</option>
                                    <option value="Grey">Grey</option>
                                    <option value="Red">Red</option>
                                    <option value="Blue">Blue</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12 d-flex justify-content-end">
                                <button type="button" class="btn btn-primary shadow-sm" @onclick="async () => await AddVehicleToList()">
                                    <i class="bi @(onUpdate ? "bi-arrow-repeat" : "bi-plus-circle") me-1"></i>
                                    @(onUpdate ? "Update" : "Add Vehicle")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TABLE CARD -->
                @if (newVehicleList.Any())
                {
                    <div class="col-12">
                        <div class="card p-4 border-0 shadow-sm">
                            <h6 class="form-section-title">
                                <i class="bi bi-table me-2"></i>Vehicle List
                            </h6>
                            <div class="table-responsive rounded shadow-sm">
                                <table class="table table-bordered table-hover table-striped mb-0 align-middle bg-white">
                                    <thead class="table-light">
                                        <tr>
                                            <th>IC No</th>
                                            <th>Vehicle No</th>
                                            <th>Brand</th>
                                            <th>Model</th>
                                            <th>Color</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var v in pagedNewVehicles)
                                        {
                                            <tr>
                                                <td class="text-center">@v.IC_No</td>
                                                <td class="text-center">@v.VehicleNo</td>
                                                <td class="text-center">@v.brand</td>
                                                <td class="text-center">@v.Model</td>
                                                <td class="text-center">@v.Color</td>
                                                <td class="text-center">
                                                    <div class="d-flex justify-content-center gap-1">
                                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                                title="Edit"
                                                                @onclick="() => EditVehicleInList(v)">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                                title="Remove"
                                                                @onclick="async () => await RemoveVehicleFromList(v)">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="row mt-4">
                                <div class="col-md-12 d-flex justify-content-end">
                                    <button type="button" class="btn btn-success btn-lg px-5 shadow fw-bold" @onclick="SaveAllVehicles">
                                        Save
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>